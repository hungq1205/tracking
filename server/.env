# VLM model — local path takes priority if it exists, falls back to HuggingFace ID
VLM_MODEL_PATH=/models/qwen/3B
VLM_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct

# Intent parser model (runs on CPU)
INTENT_PARSER_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct

# Directory for JSON memory store and RAG index
MEMORY_STORE_DIR=

# PaddleOCR microservice URL
OCR_SERVER_URL=http://localhost:8100
